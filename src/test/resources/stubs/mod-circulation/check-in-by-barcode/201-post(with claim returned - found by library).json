{
  "request": {
    "method": "POST",
    "urlPath": "/circulation/check-in-by-barcode",
    "bodyPatterns": [
      {
        "equalToJson": {
          "itemBarcode": "DCB_ITEM",
          "claimedReturnedResolution": "Found by library"
        },
        "ignoreExtraElements": true
      },
      { "matchesJsonPath": "$.checkInDate" },
      {
        "matchesJsonPath": {
          "expression": "$.servicePointId",
          "matches": "[0-9a-f-]{36}"
        }
      }
    ],
    "headers": {
      "x-okapi-tenant": {
        "equalTo": "test_tenant"
      }
    }
  },
  "response": {
    "status": 201,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "loan": {
        "id": "cf23adf0-61ba-4887-bf82-956c4aae2260",
        "userId": "df7f4993-8c14-4a0f-ab63-93975ab01c76",
        "itemId": "5b95877d-86c0-4cb7-a0cd-7660b348ae5a",
        "item": {
          "title": "The Long Way to a Small, Angry Planet",
          "barcode": "DCB_ITEM",
          "status": {
            "name": "Checked out"
          }
        },
        "loanDate": "2017-03-01T23:11:00.000Z",
        "dueDate": "2017-04-01T23:11:00.000Z",
        "checkinServicePointId": "9d1b77e8-f02e-4b7f-b296-3f2042ddac55",
        "status": {
          "name": "Closed"
        },
        "action": "checkedin"
      }
    }
  }
}
