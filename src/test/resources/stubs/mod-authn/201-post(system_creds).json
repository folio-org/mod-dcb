{
  "request": {
    "method": "POST",
    "urlPath": "/authn/credentials",
    "bodyPatterns": [
      {
        "equalToJson": {
          "username": "dcb-system-user",
          "password": "dcb-system-user@password"
        }
      }
    ],
    "headers": {
      "x-okapi-tenant": {
        "equalTo": "test_tenant"
      }
    }
  },
  "response": {
    "status": 201,
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
