<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

  <changeSet id="MODDCB-257@@create-settings-table" author="Pavel Filippov">
    <createTable tableName="settings">
      <column name="id" type="uuid">
        <constraints primaryKey="true"/>
      </column>
      <column name="scope" type="text">
        <constraints nullable="false"/>
      </column>
      <column name="key" type="text">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="value" type="jsonb"/>
      <column name="version" type="integer">
        <constraints nullable="false"/>
      </column>
      <column name="created_date" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="uuid"/>
      <column name="updated_date" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="updated_by" type="uuid"/>
    </createTable>
  </changeSet>

</databaseChangeLog>
